:80 {
        redir https://{host}{uri} permanent
}

:443 {
        log

        #tls /etc/letsencrypt/live/x1-x.com/fullchain.pem /etc/letsencrypt/live/x1-x.com/privkey.pem
        tls /etc/letsencrypt/live/securedevwarrior.com/fullchain.pem /etc/letsencrypt/live/securedevwarrior.com/privkey.pem


        header {
                -Server
                +X-Robots-Tag "noindex, nofollow, nosnippet, noarchive"
        }

        # Debug Server
        @debug host debug.securedevwarrior.com
        handle @debug {
                header {
                        +Access-Control-Allow-Origin "*"
                        +Access-Control-Allow-Methods "GET, POST, OPTIONS, HEAD"
                        +Access-Control-Allow-Headers "Content-Type, Authorization"
                }
                @options method OPTIONS
                respond @options 204
                reverse_proxy debug-server:8081 {
                        header_up Host {host}
                        header_up X-Real-IP {remote_host}
                        header_down -Access-Control-Allow-Origin
                        header_down -Access-Control-Allow-Methods
                        header_down -Access-Control-Allow-Headers
                        header_down -Access-Control-Allow-Credentials
                }
        }

        # Pescador
        @pescador host pescador.securedevwarrior.com *.pescador.securedevwarrior.com
        handle @pescador {
                header {
                        +X-Content-Type-Options "nosniff"
                }
                reverse_proxy pescador:58082 {
                        header_up Host {host}
                        header_up X-Real-IP {remote_host}
                }
        }

        # Browser Front (browser.securedevwarrior.com)
        @browser_front host browser.securedevwarrior.com
        handle @browser_front {
                header {
                        +X-Content-Type-Options "nosniff"
                }
                reverse_proxy browser-front:3001 {
                        header_up Host {host}
                        header_up X-Real-IP {remote_host}
                }
        }

        # Example Page (securedevwarrior.com, www y masosl)
        @example_page host securedevwarrior.com www.securedevwarrior.com masosl.securedevwarrior.com
        handle @example_page {
                header {
                        +X-Content-Type-Options "nosniff"
                }
                reverse_proxy example-page:3002 {
                        header_up Host {host}
                        header_up X-Real-IP {remote_host}
                }
        }

        # Host no reconocido
        handle {
                respond "Host no configurado" 404
        }
}


